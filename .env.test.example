# Integration Test Environment Variables
# Copy to .env.test and fill in values for local testing

# PostgreSQL (test database)
POSTGRES_URI=postgres://breezy_test:breezy_test@localhost:5432/breezy_test

# MongoDB (test database)
MONGO_URI=mongodb://localhost:27017/breezy_test

# JWT Secret (test only — never use in production)
JWT_SECRET=test-secret-for-jwt-signing
