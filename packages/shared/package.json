{
  "name": "@breezy/shared",
  "version": "1.0.0",
  "description": "Shared utilities and types for Breezy services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "db:migrate": "sequelize-cli db:migrate --config config/config.json",
    "db:migrate:undo": "sequelize-cli db:migrate:undo --config config/config.json",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all --config config/config.json"
  },
