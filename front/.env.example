# Front-end Breezy — variables d'environnement
# Copier en .env.local pour le dev local.

# URL publique de l'API, exposée par le reverse-proxy nginx sous /api.
# Inlinée au build Next.js (préfixe NEXT_PUBLIC_).
# - via docker-compose : http://localhost/api (nginx port 80)
NEXT_PUBLIC_API_URL=http://localhost/api
