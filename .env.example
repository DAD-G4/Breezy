# Breezy Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3000

# PostgreSQL
POSTGRES_URI=postgres://breezy:breezy@localhost:5432/breezy
POSTGRES_DB=breezy
POSTGRES_USER=breezy
POSTGRES_PASSWORD=breezy
PG_DATABASE_TEST=breezy_test
PG_HOST=localhost
PG_PORT=5432

# MongoDB
MONGO_URI=mongodb://localhost:27017/breezy

# Authentication
# Secret de signature des JWT — DOIT être long et aléatoire en production.
# Générer avec : openssl rand -hex 48
JWT_SECRET=your_jwt_secret_here
# ⚠️ PRODUCTION : les cookies d'auth sont posés avec l'option `secure` quand
# NODE_ENV=production → ils ne transitent QUE sur HTTPS. Servir l'app derrière
# une terminaison TLS (HTTPS sur nginx) sinon l'authentification échoue.

# Front-end (build arg du service `frontend` dans docker-compose).
# URL publique de l'API exposée par nginx, inlinée au build Next.js.
NEXT_PUBLIC_API_URL=http://localhost/api
