# Breezy Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3000

# PostgreSQL (used by app runtime via POSTGRES_URI)
POSTGRES_URI=postgres://breezy:breezy@localhost:5432/breezy

# PostgreSQL (used by Sequelize CLI for migrations)
PG_USER=breezy
PG_PASSWORD=breezy
PG_DATABASE=breezy
PG_DATABASE_TEST=breezy_test
PG_HOST=localhost
PG_PORT=5432

# MongoDB
MONGO_URI=mongodb://localhost:27017/breezy

# Authentication
JWT_SECRET=your_jwt_secret_here

# Front-end (build arg du service `frontend` dans docker-compose).
# URL publique de l'API exposée par nginx, inlinée au build Next.js.
NEXT_PUBLIC_API_URL=http://localhost/api
